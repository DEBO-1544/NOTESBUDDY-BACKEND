{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
"allowImportingTsExtensions": true,
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": ["src", "prisma/seed.ts"],
  "exclude": ["node_modules"]
}
